const GAS_URL = ''; // ←ここに https://script.google.com/macros/s/XXXXX/exec を貼る

// ---------- 起動チェック ----------
window.addEventListener('DOMContentLoaded', () => {
  if (!GAS_URL) {
    document.getElementById('api-warning').style.display = 'block';
  }
});

// ---------- GAS呼び出し共通 ----------
async function callGAS(action, payload) {
  if (!GAS_URL) {
    return { ok: false, error: 'GAS_URL未設定' };
  }
  try {
    // text/plain で送ることでCORSプリフライトを回避
    const res = await fetch(GAS_URL, {
      method: 'POST',
      headers: { 'Content-Type': 'text/plain;charset=utf-8' },
      body: JSON.stringify({ action, ...payload }),
      redirect: 'follow',
    });
    return await res.json();
  } catch (err) {
    return { ok: false, error: '通信エラー: ' + err.message };
  }
}

function showSync(msg, type) {
  const el = document.getElementById('sync-indicator');
  el.textContent = msg;
  el.className = 'sync-indicator visible ' + (type || '');
  clearTimeout(showSync._t);
  showSync._t = setTimeout(() => el.classList.remove('visible'), 2000);
}

// ---------- ログイン画面 ----------
function switchTab(which) {
  document.getElementById('tab-login').classList.toggle('active', which === 'login');
  document.getElementById('tab-register').classList.toggle('active', which === 'register');
  document.getElementById('form-login').style.display = which === 'login' ? 'block' : 'none';
  document.getElementById('form-register').style.display = which === 'register' ? 'block' : 'none';
  setMsg('', '');
}

function setMsg(text, type) {
  const el = document.getElementById('login-msg');
  el.textContent = text;
  el.className = 'login-msg' + (type ? ' ' + type : '');
}

async function doLogin() {
  const email = document.getElementById('login-email').value.trim();
  if (!email) { setMsg('メールアドレスを入力してください', 'error'); return; }

  const btn = document.getElementById('btn-login');
  btn.disabled = true;
  setMsg('認証中...', '');

  const r = await callGAS('login', { email });

  if (r.ok) {
    setMsg(`ようこそ、${r.user.userName} よ`, 'success');
    setTimeout(() => enterApp(r.user), 800);
  } else if (r.error === 'NOT_FOUND') {
    setMsg('未登録のメールアドレスです。「REGISTER」タブから新規登録してください', 'error');
    btn.disabled = false;
  } else {
    setMsg(r.error || 'ログイン失敗', 'error');
    btn.disabled = false;
  }
}

async function doRegister() {
  const email = document.getElementById('reg-email').value.trim();
  const userName = document.getElementById('reg-name').value.trim();
  if (!email || !userName) { setMsg('メールアドレスとユーザー名を入力してください', 'error'); return; }

  const btn = document.getElementById('btn-register');
  btn.disabled = true;
  setMsg('登録中...', '');

  const r = await callGAS('register', { email, userName });

  if (r.ok) {
    setMsg(`「${r.user.userName}」の魂が記録されました（ID: ${r.user.id}）`, 'success');
    setTimeout(() => enterApp(r.user), 1200);
  } else {
    setMsg(r.error || '登録失敗', 'error');
    btn.disabled = false;
  }
}

function enterApp(user) {
  state.user = user;
  state.player.maxFloor = user.maxFloor || 1;
  document.getElementById('user-info').textContent = `${user.userName} (ID: ${user.id})`;
  document.getElementById('login-screen').style.display = 'none';
  document.getElementById('app').classList.remove('hidden');
  startGame();
}

function doLogout() {
  if (!confirm('セッションを終了しますか？')) return;
  location.reload();
}

/* ===========================================================
   ゲーム状態
   =========================================================== */
const state = {
  user: null,
  player: { name: '名もなき詠唱者', hp: 100, hpMax: 100, mp: 50, mpMax: 50, essence: 0, maxFloor: 1 },
  dungeon: { floor: 1, room: 1, totalRooms: 3 },
  enemy: null,
  phase: 'intro',
};

const enemyPool = [
  { name: '腐敗せし墓守', icon: '☠', hp: 35, atk: 8, weak: ['炎','光'], lore: '苔むした鎧の隙間から青白い瘴気が漏れ出している。' },
  { name: '影喰らいの蝙蝠', icon: '🦇', hp: 22, atk: 6, weak: ['光','音'], lore: '闇から滲み出るように現れ、無数の翼が空気を切り裂く。' },
  { name: '骨砕きの鬼', icon: '👹', hp: 55, atk: 14, weak: ['雷','聖'], lore: '人間の骨で編まれた首飾りを揺らし、地響きと共に立ちはだかる。' },
  { name: '囁く水鏡', icon: '🪞', hp: 30, atk: 10, weak: ['炎','凍'], lore: '水面に映るのは、かつての自分の姿。鏡の奥から細い指が伸びてくる。' },
  { name: '黄金喰らいの蛞蝓', icon: '🐌', hp: 45, atk: 7, weak: ['塩','炎'], lore: '体表に金貨が埋め込まれ、ぬらりと光っている。' },
  { name: '深淵の番人', icon: '👁', hp: 80, atk: 18, weak: ['光','聖'], lore: '六本の腕を持ち、その瞳の奥には星々が渦巻いている。' },
];

const $stage = document.getElementById('stage');
const $stageContent = document.getElementById('stage-content');
const $caption = document.getElementById('caption');
const $choices = document.getElementById('choices');

function setStage({icon, title, meta, enemy}) {
  let html = `<div class="stage-icon">${icon || '✦'}</div>`;
  if (title) html += `<div class="stage-title">${title}</div>`;
  if (meta) html += `<div class="stage-meta">${meta}</div>`;
  if (enemy) {
    const pct = Math.max(0, (enemy.hp / enemy.hpMax) * 100);
    html += `<div class="enemy-hp-bar"><div class="enemy-hp-fill" style="width:${pct}%"></div></div>`;
  }
  $stageContent.innerHTML = html;
}

function flashStage(type) {
  $stage.classList.remove('flash-attack', 'flash-hit');
  void $stage.offsetWidth;
  $stage.classList.add('flash-' + type);
}

function caption(html) { $caption.innerHTML = html; $caption.scrollTop = 0; }
function captionAdd(html) { $caption.innerHTML += '<br>' + html; $caption.scrollTop = $caption.scrollHeight; }

function updateStats() {
  document.getElementById('stat-fl').textContent = state.dungeon.floor;
  document.getElementById('stat-hp').textContent = state.player.hp;
  document.getElementById('stat-mp').textContent = state.player.mp;
  document.getElementById('stat-es').textContent = state.player.essence;
}

function calcCost(text) {
  const len = [...text].length;
  let cost = Math.ceil(len * 1.2);
  const heavy = ['永劫','絶対','神','滅','黄金','深淵','業','暴','焔','雷','凍','聖'];
  heavy.forEach(w => { if (text.includes(w)) cost += 5; });
  return cost;
}

function setChoices(choices) {
  $choices.innerHTML = '';
  const padded = [...choices];
  while (padded.length < 4 && padded.length > 0 && padded.length !== 1) padded.push(null);
  padded.forEach(c => {
    const btn = document.createElement('button');
    btn.className = 'choice-btn';
    if (c) {
      btn.innerHTML = c.label + (c.meta ? `<span class="meta">${c.meta}</span>` : '');
      btn.onclick = c.action;
    } else {
      btn.innerHTML = '<span style="opacity:0.2">─</span>';
      btn.disabled = true;
    }
    $choices.appendChild(btn);
  });
}

function showCastInput() {
  $choices.innerHTML = `
    <div class="cast-overlay">
      <input id="cast-input" type="text" placeholder="言葉を紡げ — 例: 燃え盛る赤き刃" maxlength="80" autofocus>
      <span class="cost-display" id="cost-display">0/${state.player.mp}</span>
      <button class="cast-confirm" id="cast-confirm">詠唱</button>
    </div>
    <button class="choice-btn" onclick="combatChoices()">← 戻る<span class="meta">CANCEL</span></button>
    <button class="choice-btn" disabled><span style="opacity:0.2">─</span></button>
  `;
  const $input = document.getElementById('cast-input');
  const $cost = document.getElementById('cost-display');
  const $confirm = document.getElementById('cast-confirm');

  function updateCost() {
    const c = calcCost($input.value.trim());
    $cost.textContent = `${c}/${state.player.mp}`;
    $cost.classList.toggle('over', c > state.player.mp);
  }
  $input.addEventListener('input', updateCost);
  $input.addEventListener('keydown', e => { if (e.key === 'Enter') doCast(); });
  $confirm.onclick = doCast;
  $input.focus();

  async function doCast() {
    const text = $input.value.trim();
    if (!text) return;
    const cost = calcCost(text);
    if (cost > state.player.mp) {
      caption(`<span class="system">魔力が足りない。必要MP: ${cost} / 現在MP: ${state.player.mp}</span>`);
      return;
    }
    await castSpell(text, cost);
  }
}

/* ===========================================================
   ★ AI応答（ダミー）— ここをGemini APIに差し替える
   =========================================================== */
async function generateSpellEffect({prompt, cost, enemy}) {
  await new Promise(r => setTimeout(r, 700 + Math.random() * 400));

  const elementMap = {
    '炎': ['炎','焔','火','燃','焼','業火','灼'],
    '凍': ['氷','凍','凍結','雪','吹雪','寒'],
    '雷': ['雷','電','稲妻','轟','閃光'],
    '光': ['光','聖','輝','黄金','陽'],
    '闇': ['闇','影','黒','虚','深淵'],
    '音': ['音','響','鐘','叫','咆哮'],
    '塩': ['塩','清め'],
  };
  let element = '無';
  for (const [el, kws] of Object.entries(elementMap)) {
    if (kws.some(k => prompt.includes(k))) { element = el; break; }
  }

  let damage = Math.floor(cost * 0.8 + Math.random() * 6);
  const weakHit = enemy && enemy.weak.includes(element);
  if (weakHit) damage = Math.floor(damage * 1.6);

  const flavors = {
    '炎': `紅蓮の炎が螺旋を描いて${enemy.name}を包む`,
    '凍': `空気が凍てつき、${enemy.name}の動きが鈍る`,
    '雷': `閃光が走り、${enemy.name}を貫く`,
    '光': `眩い光輝が${enemy.name}を浄化せんと迸る`,
    '闇': `黒い触手が${enemy.name}に絡みつく`,
    '音': `不協和音が${enemy.name}の精神を揺さぶる`,
    '塩': `祓いの結晶が${enemy.name}に降り注ぐ`,
    '無': `形なき念が${enemy.name}を打つ`,
  };

  return { damage, element, weakHit, flavor: flavors[element] };
}

/* ===========================================================
   ゲーム進行
   =========================================================== */
function startGame() {
  setStage({ icon: '🜲', title: `第 ${state.dungeon.floor} 階層`, meta: `${state.dungeon.totalRooms} ROOMS AHEAD` });
  caption(`<span class="enemy-name">${state.user.userName}</span> よ、ようこそ Promptia へ。<br>湿った石段を降りる。${state.dungeon.totalRooms}つの間が君を待っている。<br><span class="system">最高到達: 第 ${state.player.maxFloor} 階層</span>`);
  setChoices([{ label: '進む', action: nextRoom, meta: 'ADVANCE' }]);
  updateStats();
}

function nextRoom() {
  state.phase = 'combat';
  let enemy;
  if (state.dungeon.room === state.dungeon.totalRooms) {
    enemy = {...enemyPool[5]};
  } else {
    const pool = enemyPool.slice(0, 5);
    enemy = {...pool[Math.floor(Math.random() * pool.length)]};
  }
  enemy.hpMax = enemy.hp;
  state.enemy = enemy;
  updateStats();

  setStage({
    icon: enemy.icon,
    title: enemy.name,
    meta: `ROOM ${state.dungeon.room}/${state.dungeon.totalRooms} · 弱点: ${enemy.weak.join('・')}`,
    enemy,
  });
  caption(`<span class="enemy-name">${enemy.name}</span> が現れた。<br><span class="system">${enemy.lore}</span>`);
  combatChoices();
}

function combatChoices() {
  setChoices([
    { label: '詠唱する', action: showCastInput, meta: 'CAST SPELL' },
    { label: '休む', action: tryRest, meta: 'MP +5' },
    { label: '観察', action: observe, meta: 'INSPECT' },
    { label: '逃げる', action: tryEscape, meta: 'HP -10' },
  ]);
}

function tryRest() {
  const recover = 5 + Math.floor(Math.random() * 5);
  state.player.mp = Math.min(state.player.mpMax, state.player.mp + recover);
  updateStats();
  caption(`君は呼吸を整える。魔力が <span class="weak">+${recover}</span> 戻った。`);
  setTimeout(() => enemyAttack(), 800);
}

function observe() {
  const e = state.enemy;
  caption(`<span class="enemy-name">${e.name}</span> をじっと見つめる。<br>HP: ${e.hp}/${e.hpMax} · 攻撃力: ${e.atk} · 弱点: <span class="weak">${e.weak.join('・')}</span>`);
  setTimeout(combatChoices, 100);
}

function tryEscape() {
  state.player.hp = Math.max(0, state.player.hp - 10);
  updateStats();
  caption(`君は背を向け、暗闇の中を駆ける。背後の咆哮が骨に響く。<span class="hurt"> HP -10</span>`);
  if (state.player.hp <= 0) return defeat();
  setTimeout(advanceRoom, 1200);
}

async function castSpell(text, cost) {
  state.player.mp -= cost;
  updateStats();

  caption(`<span style="color:var(--neon-blue)">「${text}」</span><br><span class="typing system">魔力が編まれてゆく</span>`);
  flashStage('attack');

  const result = await generateSpellEffect({ prompt: text, cost, enemy: state.enemy });

  let line = `${result.flavor}。<span class="damage"> ${result.damage} ダメージ</span>`;
  if (result.weakHit) line += ` <span class="weak">弱点ヒット！</span>`;
  caption(line);

  state.enemy.hp -= result.damage;
  setStage({
    icon: state.enemy.icon,
    title: state.enemy.name,
    meta: `HP ${Math.max(0, state.enemy.hp)}/${state.enemy.hpMax}`,
    enemy: state.enemy,
  });

  if (state.enemy.hp <= 0) { setTimeout(enemyDefeated, 800); return; }
  setTimeout(() => enemyAttack(), 900);
}

function enemyAttack() {
  const dmg = Math.max(1, state.enemy.atk + Math.floor(Math.random() * 4) - 2);
  state.player.hp = Math.max(0, state.player.hp - dmg);
  state.player.mp = Math.min(state.player.mpMax, state.player.mp + 8);
  updateStats();
  flashStage('hit');
  captionAdd(`<span class="enemy-name">${state.enemy.name}</span> の反撃。<span class="hurt"> ${dmg} ダメージ</span>。<span class="system">魔力 +8</span>`);
  if (state.player.hp <= 0) return defeat();
  setTimeout(combatChoices, 600);
}

function enemyDefeated() {
  const reward = Math.floor(state.enemy.hpMax / 4);
  state.player.essence += reward;
  state.player.hp = Math.min(state.player.hpMax, state.player.hp + 10);
  state.player.mp = Math.min(state.player.mpMax, state.player.mp + 15);
  updateStats();

  setStage({ icon: '✧', title: 'VICTORY', meta: `+${reward} ESSENCE` });
  caption(`<span class="enemy-name">${state.enemy.name}</span> は塵となって崩れ落ちた。<br><span class="system">星屑を ${reward} 得た。傷が少し癒える。</span>`);

  if (state.dungeon.room >= state.dungeon.totalRooms) {
    setTimeout(floorClear, 1400);
  } else {
    setTimeout(() => {
      setChoices([
        { label: '次の間へ', action: advanceRoom, meta: 'NEXT ROOM' },
        { label: '深く休む', action: deepRest, meta: '★-5 全回復' },
      ]);
    }, 1000);
  }
}

function deepRest() {
  if (state.player.essence < 5) {
    caption('<span class="system">星屑が足りない。</span>');
    setChoices([{ label: '次の間へ', action: advanceRoom, meta: 'NEXT ROOM' }]);
    return;
  }
  state.player.essence -= 5;
  state.player.hp = state.player.hpMax;
  state.player.mp = state.player.mpMax;
  updateStats();
  caption('君は壁にもたれ、深く呼吸する。傷は塞がり、魔力は満ちた。');
  setTimeout(advanceRoom, 1000);
}

function advanceRoom() {
  state.dungeon.room++;
  nextRoom();
}

async function floorClear() {
  setStage({ icon: '⬇', title: `FLOOR ${state.dungeon.floor} CLEAR`, meta: 'A NEW DEPTH OPENS' });
  caption(`深淵の番人が崩れ落ちると、床に下層への階段が口を開けた。`);

  // ★ サーバーに到達階層を送信（最高記録更新時のみ）
  await syncFloor(state.dungeon.floor);

  setChoices([
    { label: '降りる', action: nextFloor, meta: 'NEXT FLOOR' },
    { label: '帰還する', action: endGame, meta: 'RETURN' },
  ]);
}

async function syncFloor(floor) {
  if (!state.user || !state.user.id) return;
  showSync('saving...', '');
  const r = await callGAS('updateFloor', { id: state.user.id, floor });
  if (r.ok) {
    if (r.updated) {
      state.player.maxFloor = r.maxFloor;
      showSync(`★ 最高到達更新！ 第${r.maxFloor}階層`, 'success');
      captionAdd(`<span class="weak">★ 最高到達記録を更新した（第 ${r.maxFloor} 階層）</span>`);
    } else {
      showSync('saved', 'success');
    }
  } else {
    showSync('sync error', 'error');
  }
}

function nextFloor() {
  state.dungeon.floor++;
  state.dungeon.room = 1;
  state.dungeon.totalRooms = 3 + state.dungeon.floor;
  state.player.hpMax += 20; state.player.hp = state.player.hpMax;
  state.player.mpMax += 10; state.player.mp = state.player.mpMax;
  enemyPool.forEach(e => { e.hp = Math.floor(e.hp * 1.3); e.atk = Math.floor(e.atk * 1.2); });
  updateStats();
  startGame();
}

function defeat() {
  setStage({ icon: '✟', title: 'GAME OVER', meta: `第 ${state.dungeon.floor} 階層 / 第 ${state.dungeon.room} の間` });
  caption(`<span class="hurt">君の言葉は、ここで途絶えた。</span><br><span class="system">獲得した星屑: ${state.player.essence}</span>`);
  setChoices([{ label: '最初から', action: () => location.reload(), meta: 'RESTART' }]);
}

function endGame() {
  setStage({ icon: '✦', title: 'RETURNED', meta: `★ ${state.player.essence} BROUGHT BACK` });
  caption(`君は地下迷宮を後にした。<br>持ち帰った星屑: <span class="weak">${state.player.essence}</span>`);
  setChoices([{ label: 'もう一度', action: () => location.reload(), meta: 'AGAIN' }]);
}

// ---------- Enter キーでログイン/登録 ----------
document.getElementById('login-email').addEventListener('keydown', e => {
  if (e.key === 'Enter') doLogin();
});
document.getElementById('reg-email').addEventListener('keydown', e => {
  if (e.key === 'Enter') document.getElementById('reg-name').focus();
});
document.getElementById('reg-name').addEventListener('keydown', e => {
  if (e.key === 'Enter') doRegister();
});
</script>
